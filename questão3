// Representação de um ponto 2D no campo
struct Vector2D {
double x, y;
Vector2D(double _x = 0.0, double _y = 0.0) : x(_x), y(_y) {}
double length() const { return std::sqrt(x*x + y*y); }
Vector2D operator-(const Vector2D& other) const { return Vector2D(x -
other.x, y - other.y); }
// Outras operações como adição, multiplicação por escalar, etc., seriam
definidas aqui.
};
// Estrutura de um nó no Grafo de Visibilidade VSS para o A*
struct VSSNode {
Vector2D pos; // Posição 2D do nó
double g; // Custo do início até este nó
double h; // Heurística (custo estimado) deste nó até o alvo
VSSNode* parent; // Ponteiro para o nó pai para reconstruir o caminho
VSSNode(Vector2D p) : pos(p), g(std::numeric_limits<double>::max()),
h(0.0), parent(nullptr) {}
double f() const { return g + h; } // Função de avaliação
// Operador de comparação para a fila de prioridade (menor f() tem maior
prioridade)
bool operator>(const VSSNode& other) const {
return f() > other.f();
}
// Para usar em std::set ou std::map, precisamos de um operador < ou um
hash
bool operator<(const VSSNode& other) const {
if (pos.x != other.pos.x) return pos.x < other.pos.x;
return pos.y < other.pos.y;
}
};
// Heurística ideal para VSS: Distância Euclidiana
// É admissível (nunca superestima o custo real) e consistente.
double getHeuristic(const Vector2D& a, const Vector2D& b) {
return (a - b).length();
}
